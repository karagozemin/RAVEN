# RAVEN configuration — copy to .env and fill in

# --- Feed mode: live | replay ---
# live   -> connect to real TxLINE SSE endpoint (and record to disk)
# replay -> read previously recorded real TxLINE data from disk
RAVEN_FEED_MODE=replay

# --- TxLINE (real endpoint; fill from docs at txline.txodds.com) ---
# SSE base URL for live odds/scores stream
TXLINE_SSE_URL=
# API key / bearer token issued for the hackathon
TXLINE_API_KEY=
# Competition / world cup scope identifier (from worldcup docs)
TXLINE_COMPETITION=worldcup
# Service level: 1 (60s delayed, free) or 12 (real-time)
TXLINE_SERVICE_LEVEL=12

# --- Recording (used in live mode) ---
# Directory where raw real TxLINE frames are persisted for later replay
RAVEN_RECORD_DIR=data/recordings

# --- Replay ---
# Recording file to replay (real captured TxLINE data — NOT mock)
RAVEN_REPLAY_FILE=data/recordings/latest.jsonl
# Playback speed multiplier (1.0 = real time, 100 = 100x, 0 = as-fast-as-possible)
RAVEN_REPLAY_SPEED=50

# --- Solana (Decision Receipts, later layer) ---
SOLANA_CLUSTER=devnet
SOLANA_KEYPAIR_PATH=
